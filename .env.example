# ─── LLM Provider ───────────────────────────────────────────────
# Default: ollama (local). Switch by changing LLM_PROVIDER.
# Options: ollama | openai | gemini | vertex | vllm
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b          # model tag for ollama; or gpt-4o-mini, gemini-2.5-flash, etc.

OLLAMA_BASE_URL=http://ollama:11434    # docker service name; use http://localhost:11434 locally
VLLM_BASE_URL=http://vllm:8000

OPENAI_API_KEY=
GEMINI_API_KEY=

# Vertex AI (Google Cloud) — 使用 Vertex 呼叫 Gemini，有免費額度
# 需先執行: gcloud auth application-default login
# LLM_PROVIDER=vertex
# LLM_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Embedding model (used for RAG). Can run locally via sentence-transformers.
EMBEDDING_PROVIDER=local                     # local | openai
EMBEDDING_MODEL=BAAI/bge-m3                  # multilingual, good for zh+en

# ─── Discord ────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=                            # optional: restrict to one server

# Scheduler — 定時排程報告（08:30 盤前 / 12:00 盤中 / 14:30 收盤後）
SCHEDULE_REPORT_CHANNEL_ID=                  # 排程報告發送的頻道 ID（右鍵頻道 → 複製頻道 ID）
SCHEDULE_ENABLED=true                        # 設為 false 可關閉排程
SCHEDULE_USER_ID=0                           # 排程使用的系統 user ID，勿修改

# Channel allowlist — bot 只在指定頻道回應，留空則所有頻道都回應
ALLOWED_CHANNEL_IDS=                         # 多個頻道用逗號分隔，例如: 123456,789012

# ─── Database ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=market_agent
POSTGRES_USER=market_agent
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

# ─── News & Data Sources ────────────────────────────────────────
NEWSAPI_KEY=                                 # optional, https://newsapi.org
GNEWS_API_KEY=                               # optional, https://gnews.io

# ─── App Settings ───────────────────────────────────────────────
LOG_LEVEL=INFO
MARKET=TW                                    # TW | US | HK
MAX_NEWS_PER_RUN=30
NEWS_LOOKBACK_HOURS=24
SESSION_TTL_SECONDS=3600                     # Redis session expiry
